        "# ==========================================\n",
        "# Restaurant Recommendation System\n",
        "# ==========================================\n",
        "\n",
        "import pandas as pd\n",
        "from sklearn.preprocessing import LabelEncoder\n",
        "\n",
        "# Load Dataset\n",
        "df = pd.read_csv(\"/content/Dataset  (1).csv\")  # Change path if needed\n",
        "\n",
        "# ------------------------------------------\n",
        "# Handle Missing Values\n",
        "# ------------------------------------------\n",
        "for col in df.columns:\n",
        "    if df[col].dtype == 'object':\n",
        "        df[col] = df[col].fillna(df[col].mode()[0])\n",
        "    else:\n",
        "        df[col] = df[col].fillna(df[col].median())\n",
        "\n",
        "# ------------------------------------------\n",
        "# Encode Categorical Variables (Optional)\n",
        "# ------------------------------------------\n",
        "le = LabelEncoder()\n",
        "\n",
        "for col in df.select_dtypes(include='object').columns:\n",
        "    df[col] = le.fit_transform(df[col])\n",
        "\n",
        "# ------------------------------------------\n",
        "# Reload original dataset for displaying names\n",
        "# ------------------------------------------\n",
        "original_df = pd.read_csv(\"/content/Dataset  (1).csv\")\n",
        "\n",
        "for col in original_df.columns:\n",
        "    if original_df[col].dtype == 'object':\n",
        "        original_df[col] = original_df[col].fillna(original_df[col].mode()[0])\n",
        "    else:\n",
        "        original_df[col] = original_df[col].fillna(original_df[col].median())\n",
        "\n",
        "# ------------------------------------------\n",
        "# User Preferences\n",
        "# ------------------------------------------\n",
        "preferred_cuisine = \"North Indian\"\n",
        "preferred_price = 2        # Example: 1=Cheap, 2=Moderate, 3=Expensive, 4=Luxury\n",
        "minimum_rating = 4.0\n",
        "\n",
        "# ------------------------------------------\n",
        "# Content-Based Filtering\n",
        "# ------------------------------------------\n",
        "recommendations = original_df[\n",
        "    (original_df[\"Cuisines\"].str.contains(preferred_cuisine, case=False, na=False)) &\n",
        "    (original_df[\"Price range\"] == preferred_price) &\n",
        "    (original_df[\"Aggregate rating\"] >= minimum_rating)\n",
        "]\n",
        "\n",
        "recommendations = recommendations.sort_values(\n",
        "    by=[\"Aggregate rating\", \"Votes\"],\n",
        "    ascending=False\n",
        ")\n",
        "\n",
        "# ------------------------------------------\n",
        "# Display Recommendations\n",
        "# ------------------------------------------\n",
        "print(\"\\nRecommended Restaurants\\n\")\n",
        "\n",
        "if len(recommendations) > 0:\n",
        "    print(recommendations[\n",
        "        [\n",
        "            \"Restaurant Name\",\n",
        "            \"Cuisines\",\n",
        "            \"Average Cost for two\",\n",
        "            \"Price range\",\n",
        "            \"Aggregate rating\",\n",
        "            \"Votes\"\n",
        "        ]\n",
        "    ].head(10))\n",
        "else:\n",
        "    print(\"No matching restaurants found.\")"
      ],
